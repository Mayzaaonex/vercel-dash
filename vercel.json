{
  "version": 2,
  "functions": {
    "api/perplexity.js": {
      "maxDuration": 60
    }
  },
  "builds": [
    { "src": "api/perplexity.js", "use": "@vercel/node" },
    { "src": "api/perplexity-proxy.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/api/perplexity", "dest": "/api/perplexity.js" },
    { "src": "/api/perplexity-proxy", "dest": "/api/perplexity-proxy.js" },
    { "src": "/maker/(.*)", "dest": "/maker/$1" },
    { "src": "/downloader/(.*)", "dest": "/downloader/$1" },
    { "src": "/ai/(.*)", "dest": "/ai/$1" },
    { "src": "/stalker/(.*)", "dest": "/stalker/$1" },
    { "src": "/tools/(.*)", "dest": "/tools/$1" },
    { "src": "/search/(.*)", "dest": "/search/$1" },
    { "src": "/konvert/(.*)", "dest": "/konvert/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}